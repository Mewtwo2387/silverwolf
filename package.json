{
  "name": "silverwolf",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "start": "bun run build:css && bun run build:js && bun index.ts",
    "dev": "bun run build:css && bun run build:js && bun --watch index.ts",
    "test": "bun test --preload ./tests/setup.ts",
    "test:watch": "bun test --watch --preload ./tests/setup.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "build:css": "tailwindcss -i ./site_src/Assets/input.css -o ./site_src/Assets/styles.css --minify",
    "build:css:watch": "tailwindcss -i ./site_src/Assets/input.css -o ./site_src/Assets/styles.css --watch --minify",
    "build:js": "bun build ./site_src/Assets/app.src.js --minify --outfile ./site_src/Assets/app.js",
    "build:js:watch": "bun build ./site_src/Assets/app.src.js --minify --outfile ./site_src/Assets/app.js --watch",
    "build:images": "bun scripts/build-images.ts",
    "build:all": "bun run build:css && bun run build:js && bun run build:images",
    "card:battle": "bun tcg/tests/battleExample.ts",
    "card:generate": "bun tcg/tests/testGenerateCard.ts",
    "card:generate-items": "bun tcg/tests/testGenerateItemCard.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "canvas": "^3.2.3",
    "cheerio": "^1.2.0",
    "discord.js": "^14.26.0",
    "hono": "^4.12.14",
    "mime": "^2.5.2",
    "openai": "^6.33.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/mime": "2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "tailwindcss": "^3",
    "typescript": "^6.0.2"
  },
  "trustedDependencies": [
    "canvas",
    "skia-canvas"
  ],
  "overrides": {
    "canvas": "^3.2.3"
  }
}

{
  "name": "silverwolf",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "bun index.js",
    "start:node": "node index.js",
    "dev": "bun --watch index.js",
    "dev:node": "node --watch index.js",
    "test": "bun test",
    "test:jest": "jest --detectOpenHandles",
    "test:watch": "bun test --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.16.0",
    "canvas": "^3.2.3",
    "discord.js": "^14.26.0",
    "jsdom": "^29.0.1",
    "mime": "^2.5.2",
    "node-cron": "^3.0.3",
    "openai": "^5.12.2",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "29",
    "@types/jsdom": "^28.0.1",
    "@types/mime": "2",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./tests/setup.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {}]
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/database/"
    ],
    "coverageDirectory": "./coverage",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/config/**",
      "!src/**/*.test.ts"
    ]
  },
  "trustedDependencies": [
    "canvas",
    "skia-canvas"
  ],
  "overrides": {
    "canvas": "^3.2.3"
  }
}
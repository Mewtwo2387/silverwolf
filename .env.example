# Discord bot
TOKEN=your-discord-bot-token
CLIENT_ID=your-discord-application-client-id
DISCORD_CLIENT_SECRET=your-discord-oauth-client-secret

# Discord OAuth (website login)
OAUTH_REDIRECT_URI=http://localhost:3000/auth/discord/callback
SESSION_SECRET=replace-with-a-long-random-string

# Optional: timeout (ms) for outbound Discord API fetches
DISCORD_FETCH_TIMEOUT_MS=10000

# Comma-separated Discord user IDs allowed to use restricted commands
ALLOWED_USERS=123456789012345678,234567890123456789

# Comma-separated channel IDs that receive birthday announcements
# (can also be configured per-guild in the database)
BIRTHDAY_CHANNELS=123456789012345678

# Comma-separated channel IDs that receive World Cup match announcements
# (can also be configured via /football channel)
FOOTBALL_CHANNELS=123456789012345678

# Webhook display name used by the keyword behavior handler
WEBHOOK_NAME=grok-webhook

# AI providers
GEMINI_TOKEN=your-google-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Public origin for absolute social-embed URLs (og:image/og:url). Set this in
# production (the app sits behind a proxy on an internal http port) so untrusted
# x-forwarded-* headers can't redirect link previews to another domain.
PUBLIC_ORIGIN=https://your-domain.example

# Unsplash (used by /balls)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# API-Football key for World Cup fixtures, live scores, and goal events (api-football.com)
API_FOOTBALL_KEY=your-api-football-key

# Runtime
NODE_ENV=development

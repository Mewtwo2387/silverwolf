{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "./dist-tcg",
    "rootDir": "./tcg",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "tcg/**/*.ts",
    "tcg/utils/**/*.js"
  ],
  "exclude": [
    "tcg/tests/**",
    "node_modules",
    "dist",
    "dist-tcg"
  ]
}

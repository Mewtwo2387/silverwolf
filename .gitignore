.env
node_modules/*
*/temp/*
temp/*
backups/*
*.db
*.zip
*.csv
*.txt
*.log
_*.js
persistence/
.claude

*.db-wal
*.db-shm

# whitelist
!data/*.txt
.DS_Store

# Generated by build:css / build:js. Sources are site_src/Assets/app.src.js
# and site_src/tcg/assets/*.src.js; the Dockerfile rebuilds these into the image.
# For local dev: `bun run build:css build:js` once (or the :watch scripts).
site_src/Assets/styles.css
site_src/Assets/app.js
site_src/Assets/tcg-*.js
site_src/tcg/assets/*.js
# …but keep the *.src.js / *.lib.js client sources tracked (only the built *.js
# outputs above are generated). Without these negations `*.js` swallows the
# sources too, so a CI checkout would build with no TCG client JS.
!site_src/tcg/assets/*.src.js
!site_src/tcg/assets/*.lib.js
